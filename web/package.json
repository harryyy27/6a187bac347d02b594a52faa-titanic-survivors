{
  "name": "titanic-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "pretest": "sh -c 'if [ -d /app/node_modules ] && [ ! -e ./node_modules ]; then ln -sf /app/node_modules ./node_modules; fi'",
    "test": "vitest run --reporter=default --silent=false",
    "posttest": "true",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "react": "*",
    "react-dom": "*",
    "axios": "*",
    "zustand": "*",
    "react-hook-form": "*",
    "zod": "^3.23.8",
    "@hookform/resolvers": "^3.9.0",
    "lottie-web": "*",
    "clsx": "*"
  },
  "devDependencies": {
    "@types/react": "*",
    "@types/react-dom": "*",
    "@types/node": "*",
    "@vitejs/plugin-react": "*",
    "typescript": "*",
    "vite": "*",
    "vitest": "*",
    "@playwright/test": "*",
    "eslint": "*",
    "@typescript-eslint/parser": "*",
    "@typescript-eslint/eslint-plugin": "*",
    "eslint-plugin-react": "*",
    "eslint-plugin-react-hooks": "*",
    "eslint-plugin-import": "*",
    "eslint-config-prettier": "*",
    "prettier": "*"
  }
}
